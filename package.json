{
  "name": "marketing-jarvis",
  "version": "1.0.0",
  "description": "Iron Man-style AI Marketing Assistant — Gemini + Groq powered",
  "main": "electron/main.js",
  "author": "Marketing Jarvis",
  "license": "MIT",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "electron": "electron .",
    "start": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "form-data": "^4.0.5",
    "framer-motion": "^11.11.17",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.marketingjarvis.app",
    "productName": "Marketing Jarvis",
    "files": [
      "dist/**",
      "electron/**",
      "backend/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
